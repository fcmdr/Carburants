# =============================================================================
# Snowflake Credentials for Carburants France
# =============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.template .env
# 2. Fill in your actual credentials below
# 3. NEVER commit the .env file to git (it's already in .gitignore)
#
# FOR STREAMLIT CLOUD DEPLOYMENT:
# - Don't use this file
# - Add secrets in the Streamlit Cloud dashboard instead
# - See: https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/secrets-management
# =============================================================================

SNOWFLAKE_ACCOUNT=your_account_id
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=CARBURANTS_DEV
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=TRANSFORMER
