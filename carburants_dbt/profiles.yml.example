# Copy this file to ~/.dbt/profiles.yml and fill in your Snowflake credentials
# DO NOT commit your actual credentials to version control

carburants:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      role: TRANSFORMER
      database: CARBURANTS_DEV
      warehouse: COMPUTE_WH
      schema: PUBLIC
      threads: 4
      client_session_keep_alive: False

    prod:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      role: TRANSFORMER
      database: CARBURANTS_PROD
      warehouse: COMPUTE_WH
      schema: PUBLIC
      threads: 8
      client_session_keep_alive: False

    ci:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      role: TRANSFORMER
      database: CARBURANTS_CI
      warehouse: COMPUTE_WH
      schema: "PR_{{ env_var('PR_NUMBER', 'LOCAL') }}"
      threads: 4
      client_session_keep_alive: False
